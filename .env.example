# ─────────────────────────────────────────────
# Deployment configuration for deploy.sh
# ─────────────────────────────────────────────

# Required
BUCKET_NAME=
DISTRIBUTION_ID=        # replace with your real CloudFront distribution ID
S3_PREFIX=

# Optional (defaults shown in comments)
BUILD_DIR=                       # "build" for Create React App, "dist" for Vite
AWS_PROFILE=          # the named CLI profile you configured
BUILD_CMD=              # command that produces the build output
